{
  "meta": {
    "lastTouchedVersion": "2026.3.31"
  },
  "update": {
    "channel": "stable",
    "auto": { "enabled": true }
  },
  "auth": {
    "profiles": {
      "minimax-portal:default": {
        "provider": "minimax-portal",
        "mode": "oauth"
      }
    }
  },
  "mcp": {
    "servers": {
      "MiniMax": {
        "command": "uvx",
        "args": ["minimax-coding-plan-mcp", "-y"],
        "env": {
          "MINIMAX_API_KEY": "YOUR_MINIMAX_API_KEY",
          "MINIMAX_API_HOST": "https://api.minimaxi.com"
        }
      }
    }
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": ["claude"],
    "maxConcurrentSessions": 4,
    "stream": { "coalesceIdleMs": 300, "maxChunkChars": 1200 },
    "runtime": { "ttlMinutes": 120 }
  },
  "models": {
    "providers": {
      "minimax-portal": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "apiKey": "YOUR_MINIMAX_PORTAL_API_KEY",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.1-lightning",
            "name": "MiniMax M2.1 Lightning",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "claude-api": {
        "baseUrl": "YOUR_CLAUDE_API_BASE_URL",
        "apiKey": "YOUR_CLAUDE_API_KEY",
        "api": "anthropic-messages",
        "headers": {
          "X-Sub-Module": "YOUR_X_SUB_MODULE"
        },
        "models": [
          {
            "id": "claude-opus-4-6-thinking-high",
            "name": "Claude Opus 4 (Thinking High)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 32000
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-haiku-4-5-20251001",
            "name": "Claude Haiku 4.5",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6-thinking-low",
            "name": "claude-opus-4-6-thinking-low",
            "contextWindow": 200000
          },
          {
            "id": "claude-opus-4-6-thinking-medium",
            "name": "claude-opus-4-6-thinking-medium",
            "contextWindow": 200000
          }
        ]
      },
      "minimax-internal": {
        "baseUrl": "YOUR_MINIMAX_INTERNAL_BASE_URL",
        "apiKey": "YOUR_MINIMAX_INTERNAL_API_KEY",
        "api": "anthropic-messages",
        "headers": {
          "X-Biz-Id": "YOUR_X_BIZ_ID"
        },
        "models": [
          {
            "id": "minimax-m2.7",
            "name": "MiniMax M2.7",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      },
      "minimax-tokenplan": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "apiKey": "YOUR_MINIMAX_TOKENPLAN_API_KEY",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7 (Token Plan)",
            "api": "anthropic-messages",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.7-highspeed",
            "name": "MiniMax M2.7 Highspeed (Token Plan)",
            "api": "anthropic-messages",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "claude-api/claude-opus-4-6-thinking-high",
        "fallbacks": []
      },
      "models": {
        "claude-api/claude-opus-4-6-thinking-high": { "alias": "opus" },
        "claude-api/claude-sonnet-4-6": { "alias": "sonnet" },
        "claude-api/claude-haiku-4-5-20251001": { "alias": "haiku" },
        "minimax-internal/minimax-m2.7": { "alias": "minimax" },
        "minimax-portal/MiniMax-M2.1": { "alias": "minimax-m2.1" },
        "minimax-portal/MiniMax-M2.1-lightning": { "alias": "minimax-m2.1-lightning" },
        "minimax-tokenplan/MiniMax-M2.7": { "alias": "m2.7-tp" },
        "minimax-tokenplan/MiniMax-M2.7-highspeed": { "alias": "m2.7-hs" }
      },
      "workspace": "~/.openclaw/workspace",
      "compaction": { "mode": "safeguard" },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "model": "sonnet",
        "runTimeoutSeconds": 900
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Silvana",
          "emoji": "👑",
          "avatar": "avatars/silvana.png"
        }
      },
      {
        "id": "coder",
        "name": "Babette Lucy",
        "workspace": "~/.openclaw/workspace-coder",
        "agentDir": "~/.openclaw/agents/coder/agent",
        "skills": ["agentic-coding", "code-review", "piv", "mini-piv", "prd", "github", "coding-agent"],
        "identity": {
          "name": "Babette Lucy",
          "emoji": "🔮",
          "avatar": "avatars/bb.png"
        }
      },
      {
        "id": "scribe",
        "name": "Muse",
        "workspace": "~/.openclaw/workspace-scribe",
        "agentDir": "~/.openclaw/agents/scribe/agent",
        "model": { "primary": "claude-api/claude-sonnet-4-6" },
        "skills": ["ai-prompt-optimizer-cn", "multi-search-engine", "google-trends"],
        "identity": {
          "name": "Muse",
          "emoji": "✍️"
        }
      },
      {
        "id": "riji",
        "name": "日迹 AI",
        "workspace": "~/.openclaw/workspace-riji",
        "agentDir": "~/.openclaw/agents/riji/agent",
        "model": {
          "primary": "minimax-tokenplan/MiniMax-M2.7-highspeed",
          "fallbacks": ["minimax-internal/minimax-m2.7"]
        },
        "identity": {
          "name": "日迹",
          "emoji": "📔"
        },
        "tools": {
          "allow": ["memory_search", "memory_get", "web_search"],
          "deny": ["exec", "write", "edit", "browser", "canvas", "nodes", "cron", "gateway", "sessions_spawn"]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "coder",
      "match": { "channel": "feishu" }
    }
  ],
  "messages": { "ackReactionScope": "group-mentions" },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "dmPolicy": "pairing",
      "accounts": {
        "default": {
          "appId": "YOUR_FEISHU_APP_ID",
          "appSecret": "YOUR_FEISHU_APP_SECRET"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "tailscale": { "mode": "off", "resetOnExit": false },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    }
  },
  "plugins": {
    "allow": ["feishu", "minimax", "acpx"],
    "entries": {
      "feishu": { "enabled": true },
      "minimax": { "enabled": true },
      "acpx": { "enabled": true }
    },
    "installs": {}
  },
  "tools": {
    "exec": { "ask": "off", "security": "full" }
  }
}
